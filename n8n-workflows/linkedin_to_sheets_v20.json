        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "contents",
              "value": "={{ [{\n  \"parts\": [{\n    \"text\": \"Eres un estratega. Estas son las empresas: [Ecopetrol, Bancolombia, Grupo Aval, Suramericana, ISA, Nutresa, Grupo Argos, EPM, Avianca, Terpel, Alpina, Claro Colombia, Postobon, Bavaria, Celsia, Promigas, Banco de Bogota, Davivienda, Enel Colombia, Cementos Argos, Alqueria, Grupo Bolivar, Corficolombiana, Mineros, Tecnoglass, Valorem, Carvajal, Colombina, Manuelita, Riopaila Castilla]. Historial reciente: \" + JSON.stringify($json) + \" Decide qué empresa buscar hoy. Responde SOLO JSON: {\\\"name\\\": \\\"Nombre\\\", \\\"domain\\\" : \\\"dominio.com\\\"}\"\n  }]\n}] }}"
            }
          ]
