        "jsCode": "const companies = [\n  \"Ecopetrol\", \"Bancolombia\", \"Grupo Aval\", \"Suramericana\", \"ISA\", \"Nutresa\",\n  \"Grupo Argos\", \"Empresas Publicas de Medellin\", \"Avianca\", \"Terpel\",\n  \"Alpina\", \"Claro Colombia\", \"Movistar Colombia\", \"Postobon\", \"Bavaria\"\n];\n\nconst index = Math.floor(Date.now() / (1000 * 60 * 60)) % companies.length;\nreturn { company: companies[index] };"
