        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "fields.stats.opened.integerValue",
              "value": "1"
            }
          ]
        },
        "options": {}
      },
      "id": "update-db-v4",
      "name": "Actualizar DB",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        650,
        340
      ],
      "onError": "continueRegularOutput"
