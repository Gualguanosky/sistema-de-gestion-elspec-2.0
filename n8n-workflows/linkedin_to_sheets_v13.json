      ]
    },
    {
      "parameters": {
        "operation": "append",
        "documentId": "1R2ICBiltA6PD01Ctwa1rHIw58lqwxRm-UtYqHP8wCZk",
        "sheetName": "Hoja 1",
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "Fecha": "={{ $now.format('yyyy-MM-dd HH:mm:ss') }}",
            "Nombre": "={{ $json.data.first_name }} {{ $json.data.last_name }}",
            "Email": "={{ $json.data.email || 'No encontrado' }}",
            "Cargo": "={{ $(\"Filtro: Evitar Repetidos\").item.json.cargo }}",
            "Empresa": "={{ $(\"Filtro: Evitar Repetidos\").item.json.companyName }}",
            "LinkedIn": "={{ $(\"Filtro: Evitar Repetidos\").item.json.linkedinURL }}",
            "Confianza Email": "={{ $json.data.score || 0 }}%"
          }
