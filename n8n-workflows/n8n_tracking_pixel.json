      "position": [
        450,
        140
      ]
    },
    {
      "parameters": {
        "jsCode": "return {\n  campaignId: $input.item.json.query.campaignId\n};"
      },
      "id": "extract-id",
      "name": "Extraer ID",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        450,
        340
      ]
    },
    {
      "parameters": {
        "method": "PATCH",
        "url": "=https://firestore.googleapis.com/v1/projects/sistema-tickets-766f4/databases/(default)/documents/campaigns/{{$json.campaignId}}?updateMask.fieldPaths=stats.opened",
        "authentication": "predefinedCredentialType",
