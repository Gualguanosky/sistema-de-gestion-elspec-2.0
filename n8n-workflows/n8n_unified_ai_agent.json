    {
      "parameters": {
        "model": "gpt-4o-mini",
        "prompt": "=Eres {{ $('Bucle: Separar Contactos').item.json.senderName }}, un asesor experto técnico de Elspec. Investiga las 3 necesidades eléctricas críticas para una empresa en el sector {{ $('Bucle: Separar Contactos').item.json.industry }} en Colombia. Responde en un párrafo breve y profesional.",
        "options": {},
