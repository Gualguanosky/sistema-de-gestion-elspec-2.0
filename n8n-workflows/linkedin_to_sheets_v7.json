        "url": "=https://generativelanguage.googleapis.com/v1/models/gemini-1.5-flash:generateContent?key=AIzaSyA9alcMCjXy5ifh_-uRUVP91lofHAwcjVQ",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "contents",
              "value": "={{ [{\n  \"parts\": [{\n    \"text\": \"Extrae una lista de personas de estos resultados de búsqueda de Google (LinkedIn). Para cada persona, devuelve: nombre, cargo, empresa y URL de LinkedIn. Resultados: \" + JSON.stringify($json.organic_results || []) + \" Responde SOLO en formato JSON válido (un array de objetos). Ejemplo: [{\\\"nombre\\\": \\\"Juan Perez\\\", \\\"cargo\\\": \\\"Gerente\\\", \\\"empresa\\\": \\\"Ecopetrol\\\", \\\"linkedin\\\": \\\"url\\\"}]\"\n  }]\n}] }}"
            }
          ]
        },
        "options": {}
      },
