                "jsCode": "try {\n  const rawAiText = $json.content?.parts?.[0]?.text || $json.text || $json.data || $json.output || '[]';\n  // Limpieza robusta de Markdown JSON\n  let cleanJsonText = rawAiText.replace(/^[\\s\\S]*?```(?:json)?\\n?/i, ''); // Remueve todo ANTES del ```json\n  cleanJsonText = cleanJsonText.replace(/\\n?```[\\s\\S]*$/i, ''); // Remueve todo DESPUÉS del último ```\n  cleanJsonText = cleanJsonText.trim();\n  \n  if (!cleanJsonText.startsWith('[')) cleanJsonText = '[' + cleanJsonText;\n  if (!cleanJsonText.endsWith(']')) cleanJsonText = cleanJsonText + ']';\n\n  const results = JSON.parse(cleanJsonText);\n  \n  if (Array.isArray(results) && results.length > 0) {\n    return results.map(p => ({ json: p }));\n  } else {\n     return [{ json: { name: \"API de Google vacía\", error: \"Gemini no encontró prospectos\", role: \"Error\", industry: \"N/A\", companyDomain: \"\" } }];\n  }\n} catch (e) {\n  console.error(\"Error parsing Gemini JSON:\", e);\n  return [{ json: { name: \"Error en el formato AI\", error: e.message, role: \"Error\", industry: \"N/A\", companyDomain: \"\" } }];\n}"
