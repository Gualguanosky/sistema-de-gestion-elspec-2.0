            "parameters": {
                "jsCode": "try {\n  const rawAiText = $json.content?.parts?.[0]?.text || $json.text || $json.data || $json.output || '[]';\n  const cleanJsonText = rawAiText.replace(/^```json\\n?/i, '').replace(/^```\\n?/i, '').replace(/\\n?```$/i, '').trim();\n  const results = JSON.parse(cleanJsonText);\n  \n  // Asegurar que cada prospecto tenga un ID único\n  const formattedResults = results.map(p => ({\n    ...p,\n    id: p.id || Math.random().toString(36).substring(2, 9)\n  }));\n  \n  return { prospects: formattedResults };\n} catch (e) {\n  console.error(\"Error parsing Gemini JSON:\", e);\n  return { prospects: [], error: \"Error al procesar la respuesta de la IA\" };\n}"
            },
