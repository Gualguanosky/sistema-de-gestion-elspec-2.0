      "id": "node-8",
      "name": "Read Leads",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [
        1500,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "const existingLeads = $input.all();\nconst currentBatch = $node[\"Format List\"].all();\nconst existingNames = existingLeads.map(l => `${l.json.Nombre} ${l.json.Apellido}`.toLowerCase().trim());\nreturn currentBatch.filter(lead => {\n  const fullName = `${lead.json.firstName} ${lead.json.lastName}`.toLowerCase().trim();\n  return !existingNames.includes(fullName);\n});"
      },
      "id": "node-9",
      "name": "Filter Dupes",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1700,
        300
      ]
    },
    {
      "parameters": {
        "url": "=https://api.hunter.io/v2/email-finder?domain={{ $(\"Format Selection\").first().json.domain }}&first_name={{ $json.firstName }}&last_name={{ $json.lastName }}&api_key=0aa3be971b5e23ce516e21fa248e2d39feab52eb",
        "options": {}
      },
      "id": "node-10",
      "name": "Email Finder",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        1900,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "let email = $json.data.email;\nlet status = \"Hunter\";\nif (!email) {\n  const p = $(\"Filter Dupes\").item.json;\n  const dom = $(\"Format Selection\").first().json.domain;\n  email = `${p.firstName.toLowerCase()}.${p.lastName.toLowerCase()}@${dom}`;\n  status = \"IA-Pattern\";\n}\nreturn {\n  ...$json, email, status, \n  firstName: $(\"Filter Dupes\").item.json.firstName,\n  lastName: $(\"Filter Dupes\").item.json.lastName,\n  cargo: $(\"Filter Dupes\").item.json.cargo,\n  company: $(\"Format Selection\").first().json.name,\n  linkedin: $(\"Filter Dupes\").item.json.linkedinURL\n};"
      },
      "id": "node-11",
      "name": "Recovery",
      "type": "n8n-nodes-base.code",
