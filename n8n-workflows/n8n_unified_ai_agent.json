    {
      "parameters": {
      "method": "POST",
      "url": "=https://generativelanguage.googleapis.com/v1/models/gemini-1.5-flash:generateContent?key={{$env.GEMINI_API_KEY}}",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "contents.0.parts.0.text",
              "value": "=Eres un experto extractor de datos B2B. A continuación te proporciono un JSON con resultados de búsqueda web para la empresa: {{ $('Webhook Maestro').item.json.body.companyName }}\n\nTu trabajo es identificar personas y sus cargos. Extrae la información y devuélvela en formato de array de objetos JSON estricto. Campos requeridos:\n- \"name\": Nombre completo.\n- \"role\": Cargo o título.\n- \"linkedin\": URL de LinkedIn.\n- \"companyDomain\": Dominio principal de la empresa.\n- \"industry\": \"{{ $('Webhook Maestro').item.json.body.companyName }}\"\n\nDatos Web Crudos:\n{{ JSON.stringify($input.all().map(item => ({ titulo: item.json.title, snippet: item.json.snippet, link: item.json.link }))) }}\n\nOJO: SOLO devuelve el JSON RAW, sin markdown."
            }
          ]
        },
        "options": {}
      },
      "id": "prospect-gemini",
      "name": "Gemini (Parsear HTML)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        1200,
        100
      ]
    },
    {
      "parameters": {
        "jsCode": "try {\n  const rawAiText = $json.candidates?.[0]?.content?.parts?.[0]?.text || $json.content?.parts?.[0]?.text || $json.text || '[]';\n  // Limpieza robusta de Markdown JSON\n  let cleanJsonText = rawAiText.replace(/^[\\s\\S]*?```(?:json)?\\n?/i, ''); \n  cleanJsonText = cleanJsonText.replace(/\\n?```[\\s\\S]*$/i, '');\n  cleanJsonText = cleanJsonText.trim();\n  \n  if (!cleanJsonText.startsWith('[')) cleanJsonText = '[' + cleanJsonText;\n  if (!cleanJsonText.endsWith(']')) cleanJsonText = cleanJsonText + ']';\n\n  const results = JSON.parse(cleanJsonText);\n  \n  if (Array.isArray(results) && results.length > 0) {\n    return results.map(p => ({ json: p }));\n  } else {\n     return [{ json: { name: \"AI vacía\", error: \"Gemini no encontró prospectos\", role: \"Error\", industry: \"N/A\", companyDomain: \"\" } }];\n  }\n} catch (e) {\n  return [{ json: { name: \"Error en el formato AI\", error: e.message, role: \"Error\", industry: \"N/A\", companyDomain: \"\" } }];\n}"
      },
      "id": "prospect-split",
      "name": "Separar Prospectos",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1400,
        100
      ]
    },
    {
      "parameters": {
      "method": "GET",
      "url": "https://api.hunter.io/v2/domain-search",
      "sendQuery": true,
      "queryParameters": {
        "parameters": [
          {
            "name": "domain",
            "value": "={{ $json.companyDomain }}"
          },
          {
            "name": "api_key",
            "value": "={{ $env.HUNTER_API_KEY }}"
          },
          {
            "name": "limit",
            "value": "10"
          }
        ]
      },
      "options": {}
    },
      "id": "prospect-hunter",
      "name": "Hunter.io (Gratis)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        1600,
        200
      ],
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "const prospect = $('Separar Prospectos').item.json;\nconst hunterData = $json.data?.emails || [];\nconst pattern = $json.data?.pattern || '{first}.{last}';\n\nlet bestEmail = null;\nlet source = 'not_found';\n\nconst cleanStr = (str) => (str || '').normalize('NFD').replace(/[\\u0300-\\u036f]/g, '').toLowerCase().replace(/\\s/g, '');\nconst fnRaw = prospect.name ? prospect.name.split(' ')[0] : '';\nconst lnRaw = prospect.name ? (prospect.name.split(' ').slice(1).join(' ') || '') : '';\nconst fn = cleanStr(fnRaw);\nconst ln = cleanStr(lnRaw.split(' ')[0]); // Solo primer apellido para correos\n\n// 1. Intentar Match exacto en Hunter\nif (hunterData.length > 0 && prospect.name) {\n  const match = hunterData.find(e => \n    (fn && cleanStr(e.first_name).includes(fn)) || \n    (ln && cleanStr(e.last_name).includes(ln))\n  );\n  if (match) {\n    bestEmail = match.value;\n    source = 'hunter_io';\n  }\n}\n\n// 2. IA Fallback: Adivinar correo si Hunter no lo encontró pero tenemos nombre y dominio\nif (!bestEmail && fn && prospect.companyDomain) {\n    let guessed = '';\n    if (pattern.includes('{first}.{last}')) guessed = `${fn}.${ln}`;\n    else if (pattern.includes('{f}{last}')) guessed = `${fn.charAt(0)}${ln}`;\n    else if (pattern.includes('{first}{last}')) guessed = `${fn}${ln}`;\n    else if (pattern.includes('{first}_{last}')) guessed = `${fn}_${ln}`;\n    else if (pattern.includes('{last}{first}')) guessed = `${ln}${fn}`;\n    else guessed = `${fn}.${ln}`; // Por defecto\n    \n    // Fix para casos donde no hay apellido\n    guessed = guessed.replace(/^\\.|\\.$/g, '');\n    \n    bestEmail = `${guessed}@${prospect.companyDomain}`;\n    source = 'ia_estimado';\n}\n\nreturn {\n  ...prospect,\n  email: bestEmail,\n  emailSource: source,\n  id: Math.random().toString(36).substring(2, 9)\n};"
      },
