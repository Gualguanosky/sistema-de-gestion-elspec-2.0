        "path": "elspec-track-open-v3",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "webhook-v3",
      "name": "Webhook v3",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [
        200,
        240
      ],
      "webhookId": "elspec-track-open-v3"
